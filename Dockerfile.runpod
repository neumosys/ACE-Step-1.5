# ACE-Step 1.5 RunPod Serverless Dockerfile
# Optimized for GPU inference with optional LLM support
FROM nvidia/cuda:12.8.0-runtime-ubuntu22.04 AS base

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    DEBIAN_FRONTEND=noninteractive \
    TOKENIZERS_PARALLELISM=false

# Install Python 3.11 and system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3.11-dev \
    python3-pip \
    build-essential \
    git \
    curl \
    wget \
    ffmpeg \
    libsndfile1 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3.11 /usr/bin/python \
    && ln -sf /usr/bin/python3.11 /usr/bin/python3

# Create and activate virtual environment
RUN python3.11 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Create a non-root user
RUN useradd -m -u 1001 appuser

# Set working directory
WORKDIR /app

# Copy project files
COPY . /app

# Upgrade pip
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Install PyTorch with CUDA 12.8 support
RUN pip install --no-cache-dir \
    torch==2.10.0 \
    torchaudio==2.10.0 \
    torchvision \
    --index-url https://download.pytorch.org/whl/cu128

# Install flash-attn for faster attention (requires torch first)
RUN pip install --no-cache-dir flash-attn --no-build-isolation || echo "Flash attention installation failed, will use SDPA"

# Install nano-vllm from local path (required for LLM)
RUN pip install --no-cache-dir ./acestep/third_parts/nano-vllm

# Install RunPod and AWS dependencies
RUN pip install --no-cache-dir runpod boto3 hf_transfer

# Install remaining dependencies (excluding torch which is already installed)
RUN pip install --no-cache-dir \
    "transformers>=4.51.0,<4.58.0" \
    diffusers \
    "scipy>=1.10.1" \
    "soundfile>=0.13.1" \
    "loguru>=0.7.3" \
    "einops>=0.8.1" \
    "accelerate>=1.12.0" \
    "numba>=0.63.1" \
    "vector-quantize-pytorch>=1.27.15" \
    "peft>=0.7.0" \
    torchao \
    modelscope \
    huggingface-hub \
    requests \
    diskcache \
    PyYAML \
    tqdm

# Install torchcodec (for audio processing)
RUN pip install --no-cache-dir "torchcodec>=0.9.1" || echo "torchcodec installation failed"

# Install the package itself
RUN pip install --no-cache-dir -e .

# Create directories
RUN mkdir -p /app/outputs /app/checkpoints /app/logs && \
    chown -R appuser:appuser /app/outputs /app/checkpoints /app/logs

# Pre-download the HOT-PATH models into the image.
#
# Why partial bake: the full all-XL set is ~29 GB which cuts it close to
# Runpod's hard 30-min managed-build timeout. Baking only the models used
# on every request keeps the build comfortably under ~22 GB of downloads
# and frees the build to finish in ~15-20 min. The "cold path" model
# (acestep-v15-xl-base, used only by extract/lego/complete tasks) is
# auto-downloaded into /app/checkpoints by init_service_downloads.py on
# the first request that needs it - a ~3-5 min one-time penalty per
# fresh worker, paid only by v2s requests (not by song gen or remix).
#
# We baked, not network-volumed, so the endpoint is not pinned to one
# region and you can burst across GPU pools.
#
# All three downloads run in parallel inside one RUN layer. hf_transfer
# saturates bandwidth for each; parallelism squeezes a few extra minutes
# off the total.
RUN python -c "\
import concurrent.futures as cf; \
from huggingface_hub import snapshot_download; \
jobs = [ \
    ('ACE-Step/Ace-Step1.5', '/app/checkpoints'), \
    ('ACE-Step/acestep-v15-xl-turbo', '/app/checkpoints/acestep-v15-xl-turbo'), \
    ('ACE-Step/acestep-5Hz-lm-4B', '/app/checkpoints/acestep-5Hz-lm-4B'), \
]; \
ex = cf.ThreadPoolExecutor(max_workers=3); \
futs = [ex.submit(snapshot_download, repo_id=r, local_dir=d) for r, d in jobs]; \
[f.result() for f in futs] \
"

# Change ownership of app dir
RUN chown -R appuser:appuser /app

# Stay as root so the handler can write to /app/checkpoints for the
# lazy xl-base download on first v2s request. Runpod serverless workers
# are already isolated; non-root inside the container adds little.

# Expose port (for documentation)
EXPOSE 8000

# Volumes for outputs and logs only (checkpoints baked in + lazy xl-base)
VOLUME [ "/app/outputs", "/app/logs" ]

# Default environment variables (can be overridden at runtime)
# All-XL configuration: 4B DiT for every task + 4B LM planner.
# Targets L40S 48GB (or any 40GB+ GPU). For 24GB GPUs, set LM_MODEL=acestep-5Hz-lm-1.7B
#
# CHECKPOINT_DIR is the container-local /app/checkpoints (NOT a network
# volume). Hot models (xl-turbo, 4B LM, shared VAE/text encoder) are
# baked into this directory. xl-base auto-downloads here on first use.
ENV CHECKPOINT_DIR=/app/checkpoints \
    DIT_MODEL_TURBO=acestep-v15-xl-turbo \
    DIT_MODEL_BASE=acestep-v15-xl-base \
    LM_MODEL=acestep-5Hz-lm-4B \
    LM_BACKEND=vllm \
    DEVICE=cuda \
    USE_FLASH_ATTENTION=true \
    OFFLOAD_TO_CPU=false \
    ENABLE_LLM=true

# Run the handler
CMD ["python", "-u", "handler_runpod.py"]
