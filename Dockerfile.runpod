# ACE-Step 1.5 RunPod Serverless Dockerfile
# Optimized for GPU inference with optional LLM support
FROM nvidia/cuda:12.8.0-runtime-ubuntu22.04 AS base

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    DEBIAN_FRONTEND=noninteractive \
    TOKENIZERS_PARALLELISM=false

# Install Python 3.11 and system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3.11-dev \
    python3-pip \
    build-essential \
    git \
    curl \
    wget \
    ffmpeg \
    libsndfile1 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3.11 /usr/bin/python \
    && ln -sf /usr/bin/python3.11 /usr/bin/python3

# Create and activate virtual environment
RUN python3.11 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Create a non-root user
RUN useradd -m -u 1001 appuser

# Set working directory
WORKDIR /app

# Copy project files
COPY . /app

# Upgrade pip
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Install PyTorch with CUDA 12.8 support
RUN pip install --no-cache-dir \
    torch==2.10.0 \
    torchaudio==2.10.0 \
    torchvision \
    --index-url https://download.pytorch.org/whl/cu128

# Install flash-attn for faster attention (requires torch first)
RUN pip install --no-cache-dir flash-attn --no-build-isolation || echo "Flash attention installation failed, will use SDPA"

# Install nano-vllm from local path (required for LLM)
RUN pip install --no-cache-dir ./acestep/third_parts/nano-vllm

# Install RunPod and AWS dependencies
RUN pip install --no-cache-dir runpod boto3 hf_transfer

# Install remaining dependencies (excluding torch which is already installed)
RUN pip install --no-cache-dir \
    "transformers>=4.51.0,<4.58.0" \
    diffusers \
    "scipy>=1.10.1" \
    "soundfile>=0.13.1" \
    "loguru>=0.7.3" \
    "einops>=0.8.1" \
    "accelerate>=1.12.0" \
    "numba>=0.63.1" \
    "vector-quantize-pytorch>=1.27.15" \
    "peft>=0.7.0" \
    torchao \
    modelscope \
    huggingface-hub \
    requests \
    diskcache \
    PyYAML \
    tqdm

# Install torchcodec (for audio processing)
RUN pip install --no-cache-dir "torchcodec>=0.9.1" || echo "torchcodec installation failed"

# Install the package itself
RUN pip install --no-cache-dir -e .

# Create directories
RUN mkdir -p /app/outputs /app/checkpoints /app/logs && \
    chown -R appuser:appuser /app/outputs /app/checkpoints /app/logs

# Pre-download ALL models into the image so the endpoint has zero
# runtime HF dependency and can burst across any Runpod region without
# a network volume.
#
# Total download during build is ~29-32 GB which is close to Runpod's
# hard 30-min managed-build timeout. Mitigations:
#   1. All four downloads run in parallel in a SINGLE RUN layer - HF
#      serves each stream independently, so wall-clock scales with the
#      slowest stream rather than the sum. On hf_transfer that's
#      typically 8-12 min for the biggest model.
#   2. We rely on HF_HUB_ENABLE_HF_TRANSFER=1 (set in the base ENV) to
#      use the Rust-based hf_transfer backend which maxes out bandwidth.
#   3. The ThreadPoolExecutor bubbles up exceptions so the build fails
#      fast if any single download dies, instead of burning 29 min on
#      the other three before reporting.
#
# If Runpod's build network is too slow and this still times out, the
# fallback is to drop acestep-v15-xl-base from the list and let the
# acestep init_service_downloads mixin lazy-download it on first v2s
# request.
RUN python -c "\
import concurrent.futures as cf; \
from huggingface_hub import snapshot_download; \
jobs = [ \
    ('ACE-Step/Ace-Step1.5', '/app/checkpoints'), \
    ('ACE-Step/acestep-v15-xl-turbo', '/app/checkpoints/acestep-v15-xl-turbo'), \
    ('ACE-Step/acestep-v15-xl-base', '/app/checkpoints/acestep-v15-xl-base'), \
    ('ACE-Step/acestep-5Hz-lm-4B', '/app/checkpoints/acestep-5Hz-lm-4B'), \
]; \
ex = cf.ThreadPoolExecutor(max_workers=4); \
futs = [ex.submit(snapshot_download, repo_id=r, local_dir=d) for r, d in jobs]; \
[f.result() for f in futs] \
"

# Change ownership of app dir
RUN chown -R appuser:appuser /app

# Stay as root. Runpod serverless workers are already isolated; non-root
# inside the container adds little, and the baked checkpoints are owned
# by root anyway from the download step above.

# Expose port (for documentation)
EXPOSE 8000

# Volumes for outputs and logs only (all checkpoints baked into the image)
VOLUME [ "/app/outputs", "/app/logs" ]

# Default environment variables (can be overridden at runtime)
# All-XL configuration: 4B DiT for every task + 4B LM planner.
# Targets L40S 48GB (or any 40GB+ GPU). For 24GB GPUs, set LM_MODEL=acestep-5Hz-lm-1.7B
#
# CHECKPOINT_DIR is the container-local /app/checkpoints (NOT a network
# volume). All models (xl-turbo, xl-base, 4B LM, shared bundle) are
# baked into this directory at build time.
ENV CHECKPOINT_DIR=/app/checkpoints \
    DIT_MODEL_TURBO=acestep-v15-xl-turbo \
    DIT_MODEL_BASE=acestep-v15-xl-base \
    LM_MODEL=acestep-5Hz-lm-4B \
    LM_BACKEND=vllm \
    DEVICE=cuda \
    USE_FLASH_ATTENTION=true \
    OFFLOAD_TO_CPU=false \
    ENABLE_LLM=true

# Run the handler
CMD ["python", "-u", "handler_runpod.py"]
