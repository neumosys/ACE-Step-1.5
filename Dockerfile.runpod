# ACE-Step 1.5 RunPod Serverless Dockerfile
# Optimized for GPU inference with optional LLM support
FROM nvidia/cuda:12.8.0-runtime-ubuntu22.04 AS base

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    DEBIAN_FRONTEND=noninteractive \
    TOKENIZERS_PARALLELISM=false

# Install Python 3.11 and system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3.11-dev \
    python3-pip \
    build-essential \
    git \
    curl \
    wget \
    ffmpeg \
    libsndfile1 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3.11 /usr/bin/python \
    && ln -sf /usr/bin/python3.11 /usr/bin/python3

# Create and activate virtual environment
RUN python3.11 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Create a non-root user
RUN useradd -m -u 1001 appuser

# Set working directory
WORKDIR /app

# Copy project files
COPY . /app

# Upgrade pip
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Install PyTorch with CUDA 12.8 support
RUN pip install --no-cache-dir \
    torch==2.10.0 \
    torchaudio==2.10.0 \
    torchvision \
    --index-url https://download.pytorch.org/whl/cu128

# Install flash-attn for faster attention (requires torch first)
RUN pip install --no-cache-dir flash-attn --no-build-isolation || echo "Flash attention installation failed, will use SDPA"

# Install nano-vllm from local path (required for LLM)
RUN pip install --no-cache-dir ./acestep/third_parts/nano-vllm

# Install RunPod and AWS dependencies
RUN pip install --no-cache-dir runpod boto3 hf_transfer

# Install remaining dependencies (excluding torch which is already installed)
RUN pip install --no-cache-dir \
    "transformers>=4.51.0,<4.58.0" \
    diffusers \
    "scipy>=1.10.1" \
    "soundfile>=0.13.1" \
    "loguru>=0.7.3" \
    "einops>=0.8.1" \
    "accelerate>=1.12.0" \
    "numba>=0.63.1" \
    "vector-quantize-pytorch>=1.27.15" \
    "peft>=0.7.0" \
    torchao \
    modelscope \
    huggingface-hub \
    requests \
    diskcache \
    PyYAML \
    tqdm

# Install torchcodec (for audio processing)
RUN pip install --no-cache-dir "torchcodec>=0.9.1" || echo "torchcodec installation failed"

# Install the package itself
RUN pip install --no-cache-dir -e .

# Create directories. No chown here: we removed the non-root `USER appuser`
# switch below, so everything runs as root and ownership doesn't matter.
# Keeping a chown would be harmless on empty dirs but is dead code.
RUN mkdir -p /app/outputs /app/checkpoints /app/logs

# Pre-download ALL models into the image so the endpoint has zero
# runtime HF dependency and can burst across any Runpod region without
# a network volume.
#
# CRITICAL DESIGN NOTE: each model is downloaded in its OWN `RUN` layer.
# A previous iteration used a single parallel-download RUN, which made
# the HF downloads themselves fast (~45s with hf_transfer) but produced
# one ~40 GB image layer. BuildKit then spent ~47 min exporting that
# single layer and another ~20 min sending the tarball, blowing through
# Runpod's 30-min build timeout. Splitting into multiple smaller layers
# lets BuildKit parallelize extract/export/transmit across layers, and
# also means a failed retry only re-pulls the layers that changed.
#
# hf_transfer (HF_HUB_ENABLE_HF_TRANSFER=1, set in the base ENV) still
# handles each individual download at full bandwidth - we lose the
# cross-model parallelism but that was never the bottleneck.

# 1/4: Shared components from the umbrella bundle (VAE + text encoder only).
# The bundle also ships old acestep-v15-turbo (~5 GB) and old acestep-5Hz-
# lm-1.7B (~3.5 GB) which we don't use — allow_patterns skips them.
RUN python -c "from huggingface_hub import snapshot_download; snapshot_download('ACE-Step/Ace-Step1.5', local_dir='/app/checkpoints', allow_patterns=['Qwen3-Embedding-0.6B/**', 'vae/**', 'config.json', '.gitattributes'])"

# 2/4: 4B XL turbo DiT (text2music, cover, repaint) ~9 GB
RUN python -c "from huggingface_hub import snapshot_download; snapshot_download('ACE-Step/acestep-v15-xl-turbo', local_dir='/app/checkpoints/acestep-v15-xl-turbo')"

# 3/4: 4B XL base DiT (extract, lego, complete) ~9 GB
RUN python -c "from huggingface_hub import snapshot_download; snapshot_download('ACE-Step/acestep-v15-xl-base', local_dir='/app/checkpoints/acestep-v15-xl-base')"

# 4/4: 4B 5Hz LM (planner / chain-of-thought) ~8 GB
RUN python -c "from huggingface_hub import snapshot_download; snapshot_download('ACE-Step/acestep-5Hz-lm-4B', local_dir='/app/checkpoints/acestep-5Hz-lm-4B')"

# DO NOT add `RUN chown -R appuser:appuser /app` here. chown -R on a
# directory containing ~40 GB of model files causes Docker to duplicate
# every file into a new layer (OverlayFS COW on metadata change), which
# blew the Runpod 30-min build timeout on the export/tarball-send phase.
# The handler runs as root (non-root USER directive removed below) so
# ownership is already correct.

# Expose port (for documentation)
EXPOSE 8000

# Volumes for outputs and logs only (all checkpoints baked into the image)
VOLUME [ "/app/outputs", "/app/logs" ]

# Default environment variables (can be overridden at runtime)
# All-XL configuration: 4B DiT for every task + 4B LM planner.
# Targets L40S 48GB (or any 40GB+ GPU). For 24GB GPUs, set LM_MODEL=acestep-5Hz-lm-1.7B
#
# CHECKPOINT_DIR is the container-local /app/checkpoints (NOT a network
# volume). All models (xl-turbo, xl-base, 4B LM, shared bundle) are
# baked into this directory at build time.
ENV CHECKPOINT_DIR=/app/checkpoints \
    DIT_MODEL_TURBO=acestep-v15-xl-turbo \
    DIT_MODEL_BASE=acestep-v15-xl-base \
    LM_MODEL=acestep-5Hz-lm-4B \
    LM_BACKEND=vllm \
    DEVICE=cuda \
    USE_FLASH_ATTENTION=true \
    OFFLOAD_TO_CPU=false \
    ENABLE_LLM=true

# Run the handler
CMD ["python", "-u", "handler_runpod.py"]
